# ─────────────────────────────────────────────────────────────────────────────
# Kodezera Intelligence Suite — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit your .env file — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings

# ─── Database ─────────────────────────────────────────────────────────────────
# For production, point at PgBouncer (port 6432), not Postgres directly (5432)
DATABASE_URL=postgresql://kodezera:strongpassword@localhost:5432/kodezera_db
# PgBouncer production URL (use this when running docker-compose.prod.yml):
# DATABASE_URL=postgresql://kodezera:strongpassword@pgbouncer:5432/kodezera_db
POSTGRES_DB=kodezera_db
POSTGRES_USER=kodezera
POSTGRES_PASSWORD=strongpassword

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:yourredispassword@localhost:6379/0
REDIS_PASSWORD=yourredispassword
CELERY_BROKER_URL=redis://:yourredispassword@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:yourredispassword@localhost:6379/2

# ─── Qdrant Vector Database ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Local persistent path (used when QDRANT_URL points to a local process)
QDRANT_LOCAL_PATH=./qdrant_data
QDRANT_COLLECTION_NAME=kodezera_documents

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-different-from-secret-key
JWT_ACCESS_TOKEN_LIFETIME=3600      # seconds (1 hour)
JWT_REFRESH_TOKEN_LIFETIME=86400    # seconds (24 hours)

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo-preview
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ─── File Storage ─────────────────────────────────────────────────────────────
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE=52428800   # 50 MB

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# In development, leave EMAIL_BACKEND as console to print emails to stdout
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend   # production
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── Rate Limiting & Throttling ───────────────────────────────────────────────
RATELIMIT_ENABLE=True
RAG_QUERY_RATE_LIMIT=10/m         # per-user burst limit (django-ratelimit)
DOCUMENT_UPLOAD_RATE_LIMIT=20/h   # per-user upload limit

# Per-tenant DRF throttle rates (applied per tenant, not per user)
TENANT_QUERY_RATE=200/minute      # all users in a tenant combined
TENANT_UPLOAD_RATE=50/hour
USER_QUERY_RATE=30/minute         # per individual user within a tenant

# Tenant daily AI query quota (0 = unlimited; platform owners exempt)
TENANT_DAILY_QUERY_LIMIT=500

# ─── Gunicorn Tuning (production) ────────────────────────────────────────────
GUNICORN_WORKERS=5                # override auto-detect (2×CPU+1)
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
GUNICORN_MAX_REQUESTS=1000
